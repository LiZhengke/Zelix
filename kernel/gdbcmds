set architecture i386
set pagination off

target remote :1234

# Auto watch
display/i $eip
#display/x $eflags
display/x $esp


# Common breakpoints
#b _start
#b kernel_main
#b kernel_task_entry
b vPortStartFirstTask
#b vPortYieldCall
b init_task_main
#b return_to_user
#b uSysCallDispatch
#b mm_create
#b task_create
#b create_user_page_directory
#b map_user_code
#b vPortYieldCall
#b vPortTimerHandler
#b map_user_stack
#b vPortSysCall
b exception_handler
#watch *(int*)0xc011d050
#b vApplicationIdleHook
#b pxPortInitialiseStack
